# Copie para .env e preencha com seus valores reais
NODE_ENV=production
PORT=3000

# Banco de dados (DomCloud provisiona estas variáveis automaticamente)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=representacoes
DB_USER=seu_usuario
DB_PASS=sua_senha

# Sessão — gere uma string aleatória longa
SESSION_SECRET=troque_por_uma_string_aleatoria_longa_e_segura
