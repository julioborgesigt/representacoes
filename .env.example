# Copie para .env e preencha com seus valores reais
NODE_ENV=production
PORT=3000

# Banco de dados
# Opção 1 — URL única (DomCloud injeta isso automaticamente como DATABASE_URL)
# DATABASE_URL=mysql://usuario:senha@localhost:3306/nome_do_banco

# Opção 2 — variáveis separadas (use em dev local)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=representacoes
DB_USER=seu_usuario
DB_PASS=sua_senha

# Senha do admin criada pelo "npm run setup"
# Se não definida, usa "Admin@123" como padrão
ADMIN_SENHA=Admin@123

# Sessão — gere uma string aleatória longa e segura
SESSION_SECRET=troque_por_uma_string_aleatoria_longa_e_segura
